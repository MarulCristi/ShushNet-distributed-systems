{
  "name": "shushnet",
  "version": "1.0.0",
  "description": "ShushNet - Anonymous complaint escalation system",
  "private": true,
  "workspaces": [
    "shushnet/broker",
    "shushnet/apartment-client",
    "shushnet/building-manager",
    "shushnet/web-app"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=shushnet/broker\" \"npm run dev --workspace=shushnet/web-app\"",
    "dev:legacy": "concurrently \"npm run dev --workspace=shushnet/broker\" \"npm run dev --workspace=shushnet/apartment-client\" \"npm run dev --workspace=shushnet/building-manager\"",
    "dev:broker": "npm run dev --workspace=shushnet/broker",
    "dev:web": "npm run dev --workspace=shushnet/web-app",
    "build": "npm run build --workspaces",
    "install-all": "npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "rimraf": "^6.1.3"
  }
}
